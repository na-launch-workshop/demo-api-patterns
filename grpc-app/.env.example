# Server Configuration
PORT=50051
NODE_ENV=development

# PostgreSQL (Authors)
PGHOST=localhost
PGPORT=5432
PGUSER=dbuser
PGPASSWORD=dbuser
PGDATABASE=postgres

# MySQL (Books)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=appuser
MYSQL_PASSWORD=apppass
MYSQL_DATABASE=appdb

# SQLite (Reviews)
SQLITE_MOUNT_PATH=/data/sqlite
SQLITE_DB_FILE=reviews.db

# gRPC Client
GRPC_SERVER=localhost:50051
